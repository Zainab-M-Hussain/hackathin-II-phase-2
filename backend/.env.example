# Phase II Backend Environment Variables
# Copy this file to .env and fill in with your values

# Database Configuration
# For Neon: postgresql+psycopg2://user:password@region.neon.tech/database
# For local: postgresql+psycopg2://postgres:postgres@localhost:5432/todo_db
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/todo_db

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
ENVIRONMENT=development
DEBUG=true

# Logging
LOG_LEVEL=INFO
